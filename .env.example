# --- Web app ---
PORT=8088
# CHANGE THIS — used to sign JWT session tokens. Any long random string works.
JWT_SECRET=replace-me-with-a-long-random-string

# --- Single admin user ---
ADMIN_USERNAME=admin
# Default plaintext password used on first run. After first login the user is
# encouraged to change it via Settings; the new password is stored hashed in
# data/auth.json and this value is ignored thereafter.
ADMIN_PASSWORD=changeme

# --- Cloudflare ---
# Optional — populated automatically by the setup wizard. You don't need to
# set these by hand.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Paths ---
# Where cloudflared keeps its config and credentials. Don't change unless
# you've installed cloudflared in a non-standard location.
CLOUDFLARED_CONFIG_DIR=/etc/cloudflared
CLOUDFLARED_BIN=cloudflared

# Mock mode: when "true" the app fakes shell calls (cloudflared, systemctl,
# journalctl) so you can develop the UI on machines that don't have
# cloudflared installed. Set to "false" in production.
MOCK_MODE=false
